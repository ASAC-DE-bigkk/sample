# Cloudflare account
CLOUDFLARE_ACCOUNT_ID=<your-account-id>
CLOUDFLARE_API_TOKEN=

# R2/Data Catalog fixed names
R2_BUCKET_NAME=seoul
TRINO_ICEBERG_CATALOG=iceberg
SMOKE_SCHEMA=ops_smoke
DBT_TARGET=prod
R2_RAW_PREFIX=raw/sample_events

# R2 S3-compatible access
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>

# R2 Data Catalog / Iceberg REST catalog
R2_DATA_CATALOG_TOKEN=<r2-api-token-value>
R2_DATA_CATALOG_URI=<catalog-uri>
R2_DATA_CATALOG_WAREHOUSE=<warehouse>

# Dev R2/Data Catalog / Iceberg REST catalog
R2_DEV_BUCKET_NAME=seoul-dev
TRINO_DEV_ICEBERG_CATALOG=iceberg_dev
DEV_SMOKE_SCHEMA=dev_<github_id>
R2_DEV_RAW_PREFIX=dev/<github_id>/raw/sample_events
R2_DEV_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_DEV_ACCESS_KEY_ID=<dev-r2-access-key-id>
R2_DEV_SECRET_ACCESS_KEY=<dev-r2-secret-access-key>
R2_DEV_DATA_CATALOG_TOKEN=<dev-r2-api-token-value>
R2_DEV_DATA_CATALOG_URI=<dev-catalog-uri>
R2_DEV_DATA_CATALOG_WAREHOUSE=<dev-warehouse>

# Optional Wrangler R2 SQL check
WRANGLER_R2_SQL_AUTH_TOKEN=

# Airflow local runtime
AIRFLOW_UID=<id-u-result>
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=<generated-password>
AIRFLOW_ADMIN_EMAIL=<your-email>
AIRFLOW_FERNET_KEY=<generated-fernet-key>
AIRFLOW_SECRET_KEY=<generated-secret-key>

# Airflow metadata DB
POSTGRES_USER=airflow
POSTGRES_PASSWORD=<generated-postgres-password>
POSTGRES_DB=airflow
