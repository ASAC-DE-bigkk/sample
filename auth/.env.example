# auth 서비스 환경변수 (템플릿). 실값은 .env 로(gitignore). 시크릿 커밋 금지.

# 서명 키 — 운영은 반드시 강한 랜덤값으로 교체(세션·CSRF·토큰 서명 근간)
AUTH_SECRET_KEY=change-me-to-a-long-random-string
# DB — 기본 SQLite(무설정). Postgres 예: postgresql+psycopg2://user:pass@host/db
AUTH_DATABASE_URL=sqlite:///./auth.db
AUTH_BASE_URL=http://localhost:8000
# 쿠키 — 운영(HTTPS)에서는 1
AUTH_COOKIE_SECURE=0
# 수명(초)
AUTH_VERIFY_TOKEN_MAX_AGE=86400
AUTH_SESSION_MAX_AGE=3600
# 비밀번호/레이트리밋 정책
AUTH_PASSWORD_MIN_LEN=10
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=60

# ── 이메일(선택) — 값 있으면 실제 발송, 없으면 콘솔/로그로 인증 링크 출력 ──
# 필요한 값(추후 입력): SMTP_HOST/PORT/USER/PASSWORD/FROM
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@auth.local
SMTP_STARTTLS=1
